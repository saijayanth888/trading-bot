{
  "name": "quanta-frontend-v5",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Quanta Operator Console v5 — monitor / detect / intervene unified console (Vite + React 19 + Tailwind 4 + TanStack Query v5)",
  "scripts": {
    "dev": "vite",
    "codegen": "bash scripts/codegen.sh",
    "build": "npm run codegen && tsc --noEmit && vite build",
