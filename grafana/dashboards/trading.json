        "mapping": "auto",
        "series": [{"x": "score", "y": "price"}],
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "InfluxDB"},
          "query": "from(bucket: \"trading\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"sentiment\")\n  |> filter(fn: (r) => r._field == \"score\" or r._field == \"price\")\n  |> pivot(rowKey:[\"_time\", \"pair\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> filter(fn: (r) => exists r.score and exists r.price)\n  |> keep(columns: [\"_time\", \"pair\", \"score\", \"price\"])"
        }
      ]
