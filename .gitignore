# --- Python ---------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Secrets --------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
.go_live_state*
.trading-bot/
# secrets/ tree — keep README + .gitkeep, drop real key files
secrets/*
!secrets/README.md
!secrets/.gitkeep
# --- Runtime / generated state -------------------------------------------
user_data/data/onchain.db
user_data/data/onchain.db-journal
user_data/data/onchain.db-wal
user_data/data/onchain.db-shm
user_data/tradesv3.sqlite
user_data/tradesv3.sqlite-shm
user_data/tradesv3.sqlite-wal
user_data/tradesv3_nfi.sqlite
user_data/tradesv3_nfi.sqlite-shm
user_data/tradesv3_nfi.sqlite-wal
# Freqtrade auto-saves a hyperopt-style params file next to the strategy
# when running --export trades; commit only the result JSON, not this.
user_data/nfix6-*.json
# Backtest result archives are large + reproducible; commit only the
# parsed JSON + the report markdown. Re-runnable via scripts/nfi_x6_gate_check.sh.
user_data/backtest_results/backtest-result-*.zip
user_data/backtest_results/backtest-result-*.meta.json
user_data/backtest_results/.last_result.json
# Historical candle data — downloaded by freqtrade on startup
user_data/data/coinbase/*.feather
user_data/data/coinbase/*.json
# --- Logs -----------------------------------------------------------------
user_data/logs/*.log
user_data/logs/*.log.*
user_data/logs/evolution.json
!user_data/logs/.gitkeep
# --- Trained model weights -----------------------------------------------
# These are reproducible from training runs; don't bloat the repo.
user_data/models/**
!user_data/models/.gitkeep
user_data/freqai/**
user_data/freqai_data/**
user_data/freqaimodels/__pycache__/
# --- Snapshots / backups -------------------------------------------------
user_data/snapshots/**
backups/
# --- Docker volumes (compose creates them locally) ----------------------
influxdb_data/
influxdb_config/
grafana_data/
# --- Tests / coverage ----------------------------------------------------
.coverage
htmlcov/
.tox/
# --- Editors -------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
# --- Claude Code local settings ------------------------------------------
.claude/settings.local.json
# Auto-generated config backups (created by /ops regime-params apply)
user_data/config.json.bak.*
user_data/data/config-backup-*.json
# Postgres / Hermes state dumps — local-only, large, never commit
user_data/data/*.dump
user_data/data/*.tar.gz
# Hermes runtime heartbeat / pid / lock files
user_data/state/
# Stocks subsystem (shark) — runtime / cache that should be regenerated, not committed
stocks/venv/
stocks/kb/historical_bars/*.json
# Freqtrade private config — telegram token, slack webhook URL, etc.
# config.json is committed (strategy + non-secret settings); secrets live here.
user_data/config-private.json
user_data/config.json.bak-*
user_data/config.json.tmp
# Private config backups contain LIVE credentials (Telegram tokens, Slack
# webhooks, exchange API keys). NEVER commit. Rotate immediately if leaked.
user_data/config-private.json.bak*
user_data/config-private.json.tmp
*.credentials.bak
# Belt-and-suspenders against any *.bak file ending in a numeric suffix
*.bak-[0-9]*
# Debug screenshots from Playwright sessions — large binaries, not source.
.tmp_screens/
*.screenshot.png
# Operator-local screenshots (typo-spelled folder kept for compat; both forms ignored).
Screenshots/
Schreenshots/
# V3 redesign audit evidence is intentionally committed — exception below.
!docs/V3_AUDIT_EVIDENCE/screenshots/
!docs/V3_AUDIT_EVIDENCE/screenshots/**

# Operator's private review notes — kept out-of-tree by intent. Anything
# you want preserved across machines goes in docs/ instead.
private/
# Hermes-generated cron scripts: most are machine-specific and regenerated
# from the cron registry, but the hand-written wrappers checked in here
# are part of the operational design — track them.
.hermes/scripts/*
!.hermes/scripts/stocks_ml_train.sh
!.hermes/scripts/ept_training_daily.sh
!.hermes/scripts/shark_override_verify.sh
!.hermes/scripts/bt_quality_gates.sh
!.hermes/scripts/nightly_reflector.sh
!.hermes/scripts/gpu_gate.sh
!.hermes/scripts/gpu_yield_now.sh
!.hermes/scripts/gpu_resume.sh
# Unified risk peak — runtime state, regenerates on first call
user_data/data/unified_risk_peak.json
user_data/data/unified_risk_peak.json.tmp
# Wheel module — runtime state regenerates, but trade log stays
stocks/wheel/__pycache__/
# Shark subsystem ownership — runtime state, rebuilt by bootstrap script
stocks/shark/state/owned_symbols.json
stocks/shark/state/.*.owned_symbols.json.*.tmp
stocks/wheel/state/.*.owned_symbols.json.*.tmp
# LLM call tracker — append-only log, regenerates from runtime
stocks/memory/llm-calls.jsonl
.venv-exec/
.qa-venv/

# QA + workspace clutter from dashboard auditing sessions
# (headless chromium screenshots, scratch HTML)
audit-*.png
post-*.png
sent-*.png
sentiment-*.png
agent-flow-*.png
agt-zoom-*.png
ops-*.png
bottom-zoom.png
topbar-*.png
tall-*.png
zoom*.html
_zoom-*.html
# Local Claude workspace (worktrees, transcripts)
.claude/
# Wheel state backups created during reconciliation (rare)
stocks/wheel/state/*.backup-*

# Data-out-of-repo (2026-05-13): shark memory + wheel state live
# at ~/Documents/.dgx-train/shark/, NOT in this repo. The host symlinks
# stocks/memory and stocks/wheel/state point there; both must be ignored.
stocks/memory
stocks/memory/
stocks/wheel/state
stocks/wheel/state/
