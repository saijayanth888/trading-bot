{
    "max_open_trades": 6,
    "stake_currency": "USD",
    "stake_amount": "unlimited",
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "USD",
    "dry_run": true,
    "dry_run_wallet": 19000,
    "cancel_open_orders_on_exit": false,
    "trading_mode": "spot",
    "margin_mode": "",
    "timeframe": "5m",
    "bot_name": "freqtrade-meanrev",
    "initial_state": "running",
    "force_entry_enable": false,
    "unfilledtimeout": {
        "entry": 60,
        "exit": 60,
        "exit_timeout_count": 0,
        "unit": "seconds"
    },
    "order_types": {
        "entry": "limit",
        "exit": "limit",
        "emergency_exit": "limit",
        "force_entry": "limit",
        "force_exit": "limit",
        "stoploss": "limit",
        "stoploss_on_exchange": false,
        "stoploss_on_exchange_interval": 60
    },
    "order_time_in_force": {
        "entry": "GTC",
        "exit": "GTC"
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exchange": {
        "name": "coinbase",
        "key": "YOUR_COINBASE_API_KEY_HERE",
        "secret": "YOUR_COINBASE_API_SECRET_HERE",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "BTC/USD",
            "ETH/USD",
            "SOL/USD",
            "ADA/USD",
            "MATIC/USD"
        ],
        "pair_blacklist": []
    },
    "pairlists": [
        {"method": "StaticPairList"}
    ],
    "freqai": {
        "enabled": true,
        "purge_old_models": 2,
        "train_period_days": 730,
        "backtest_period_days": 14,
        "live_retrain_hours": 24,
        "expiration_hours": 26,
        "identifier": "tft_v1",
        "fit_live_predictions_candles": 300,
        "conv_width": 120,
        "feature_parameters": {
            "include_timeframes": ["5m", "15m", "1h", "4h"],
            "include_corr_pairlist": ["BTC/USD", "ETH/USD"],
            "label_period_candles": 12,
            "flat_threshold_bps": 10,
            "include_shifted_candles": 0,
            "DI_threshold": 0.9,
            "weight_factor": 0.9,
            "principal_component_analysis": false,
            "use_SVM_to_remove_outliers": true,
            "indicator_periods_candles": [10, 20],
            "noise_standard_deviation": 0.05,
            "buffer_train_data_candles": 20
        },
        "data_split_parameters": {
            "test_size": 0.20,
            "shuffle": false
        },
        "model_training_parameters": {
            "hidden_size": 64,
            "n_heads": 4,
            "dropout": 0.1,
            "var_dim": 8,
            "lr": 1e-3,
            "weight_decay": 1e-4,
            "n_epochs": 25,
            "batch_size": 256,
            "quantile_loss_weight": 0.3,
            "early_stopping_patience": 5,
            "use_amp": true,
            "use_compile": true,
            "warmup_pct": 0.05
        }
    },
    "freqaimodel": "TFTModel",
    "freqaimodel_path": "user_data/freqaimodels",
    "telegram": {
        "enabled": false,
        "token": "",
        "chat_id": ""
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "0.0.0.0",
        "listen_port": 8080,
        "verbosity": "error",
        "enable_openapi": false,
        "jwt_secret_key": "CHANGE_ME_RUN_openssl_rand_hex_32",
        "ws_token": "CHANGE_ME_WS_TOKEN",
        "CORS_origins": [],
        "username": "freqtrader",
        "password": "CHANGE_ME_PASSWORD"
    },
    "internals": {
        "process_throttle_secs": 5
    },
    "risk_management": {
        "max_portfolio_drawdown_pct": 0.08,
        "daily_loss_limit_pct": 0.03,
        "max_position_size_pct": 0.10,
        "max_concurrent_positions": 6,
        "correlation_threshold": 0.70,
        "correlation_lookback_days": 30,
        "correlation_min_overlap": 50,
        "circuit_breaker_consecutive_losses": 5,
        "circuit_breaker_cooldown_hours": 4.0,
        "kelly_enabled": true,
        "kelly_lookback_trades": 100,
        "kelly_safety_factor": 0.5,
        "kelly_max_fraction": 0.25,
        "kelly_min_trades": 10
    },
    "execution": {
        "slippage_pct": 0.003,
        "retry_attempts": 3,
        "retry_backoff_initial_sec": 1.0,
        "retry_backoff_factor": 2.0,
        "order_timeout_sec": 60,
        "poll_interval_sec": 1.0,
        "log_path": "user_data/logs/execution.log",
        "dry_run": true,
        "api_key_env": "COINBASE_API_KEY",
        "api_secret_env": "COINBASE_API_SECRET"
    },
    "logfile": "user_data/logs/freqtrade.log"
}
