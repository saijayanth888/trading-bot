# Copy to .env in the same directory as docker-compose.yml.
# `docker compose` auto-loads .env at startup.

# ============================================================================
# REQUIRED — exchange + alerts
# ============================================================================

# --- Coinbase Advanced Trade ------------------------------------------------
# https://www.coinbase.com/settings/api
# Settings → API → "New API Key" → grant View + Trade.
# Recommend an IP allowlist on the Spark's outbound IP.
COINBASE_API_KEY=
COINBASE_API_SECRET=

# --- Slack incoming webhook -------------------------------------------------
# https://api.slack.com/apps
#   1. Create New App → From scratch → name "Trading Bot" → pick a workspace
#   2. Sidebar → Incoming Webhooks → toggle On
#   3. "Add New Webhook to Workspace" → choose #trading-alerts
#   4. Copy the webhook URL below.
SLACK_WEBHOOK_URL=

# ============================================================================
# Sentiment pipeline — Perplexity (news fetcher) + Ollama (local scorer)
# ============================================================================
# Architecture: Perplexity Sonar fetches recent crypto headlines + summaries.
# A local Llama running in Ollama on the Spark scores them. No prompts about
# the bot's trades ever leave the Spark.

# --- Perplexity -------------------------------------------------------------
# https://www.perplexity.ai/settings/api → API Keys
# Sonar Online model is ~$1/M input + output tokens; ~$3-5/day at 15-min polls.
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
PERPLEXITY_RECENCY=hour      # hour | day | week | month

# --- Ollama (local) ---------------------------------------------------------
# Make sure ollama is running on the host with OLLAMA_HOST=0.0.0.0 and the
# model below is pulled. Containers reach the host via host.docker.internal.
#
#   ollama pull llama3.1:8b
#   curl http://localhost:11434/api/tags     # sanity check
#
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# ============================================================================
# OPTIONAL on-chain providers — each fails open with neutral feature values
# ============================================================================

# CryptoQuant — exchange net-flow (BTC, ETH)
# https://cryptoquant.com → user menu → My API Keys
CRYPTOQUANT_API_KEY=

# Whale Alert — large transfers (>= $1M)
# https://docs.whale-alert.io/ → Plans & Billing → Personal (free)
WHALE_ALERT_API_KEY=

# Glassnode — MVRV ratio (note: free tier excludes MVRV; leave blank to skip)
# https://glassnode.com → Account → API
GLASSNODE_API_KEY=

# ============================================================================
# Storage — PostgreSQL + TimescaleDB (port 5433 to avoid ModelForge's 5432)
# ============================================================================
POSTGRES_USER=tradebot
POSTGRES_PASSWORD=tradebot-change-me
POSTGRES_DB=tradebot

# Override only if you're not using docker compose. Inside the compose
# network the dashboard/freqtrade containers reach Postgres via the
# `postgres` service name on the internal port 5432.
# DATABASE_URL=postgresql://tradebot:tradebot-change-me@localhost:5433/tradebot

# ============================================================================
# Monitoring stack
# ============================================================================

# InfluxDB — used by the metrics writer + Grafana time-series panels.
# (TimescaleDB-backed Grafana datasources are on the roadmap; for now both
# are running so the dashboard JSON keeps working.)
INFLUX_TOKEN=                 # `openssl rand -hex 16`
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=
INFLUX_ORG=trading-bot
INFLUX_BUCKET=trading
INFLUX_RETENTION=90d

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ============================================================================
# Dashboard (TradingView-style chart UI on port 8081)
# ============================================================================
DASHBOARD_PAIRS=BTC/USD,ETH/USD,SOL/USD
DASHBOARD_TIMEFRAME=5m
DASHBOARD_WS_INTERVAL_SEC=30

# Reads the Freqtrade REST API (port 8080) for live candles + analyzed
# columns; falls back to public Coinbase data when unauthorised. Set these
# to the same username/password you put in user_data/config.json[api_server].
FREQTRADE_API_USER=freqtrader
FREQTRADE_API_PASS=
