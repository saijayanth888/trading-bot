# Copy to .env in the same directory as docker-compose.yml.
# `docker compose` auto-loads .env at startup.

# ============================================================================
# REQUIRED — exchange + alerts
# ============================================================================

# --- Coinbase Advanced Trade ------------------------------------------------
# https://www.coinbase.com/settings/api → "New API Key" → grant View + Trade.
# Set an IP allowlist on the Spark's outbound IP — strongly recommended.
#
# Workflow: download the JSON key Coinbase emits, save it as
#   ./secrets/coinbase.json   (gitignored, mounted read-only into the container)
#
# scripts/freqtrade_entrypoint.py reads it at container start and exports the
# `name` / `privateKey` fields as FREQTRADE__EXCHANGE__KEY / __SECRET so the
# placeholders in user_data/config.json[exchange] get overridden at runtime.
# You don't need to fill anything in here as long as the file is present.
COINBASE_KEY_FILE=
#
# Optional fallback (env-var auth path). Skipped when the JSON file is present.
COINBASE_API_KEY=
COINBASE_API_SECRET=

# --- Slack incoming webhook -------------------------------------------------
# https://api.slack.com/apps
#   1. Create New App → From scratch → name "Trading Bot" → pick a workspace
#   2. Sidebar → Incoming Webhooks → toggle On
#   3. "Add New Webhook to Workspace" → choose #trading-alerts
#   4. Copy the webhook URL below.
SLACK_WEBHOOK_URL=

# ============================================================================
# Sentiment pipeline — Perplexity (news fetcher) + Ollama (local scorer)
# ============================================================================
# Architecture: Perplexity Sonar fetches recent crypto headlines + summaries.
# A local Llama running in Ollama on the Spark scores them. No prompts about
# the bot's trades ever leave the Spark.

# --- Perplexity -------------------------------------------------------------
# https://www.perplexity.ai/settings/api → API Keys
# Sonar Online model is ~$1/M input + output tokens; ~$3-5/day at 15-min polls.
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
PERPLEXITY_RECENCY=hour      # hour | day | week | month

# --- Ollama (local) — all sentiment scoring runs here ---------------------
# All AI models run locally via Ollama — no external API costs.
# Make sure ollama is running on the host with OLLAMA_HOST=0.0.0.0 and the
# models below are pulled. Containers reach the host via host.docker.internal.
#
#   ollama pull hermes3:8b              # fast scanner (~5 GB)
#   ollama pull hermes3:70b      # deep thinker (~42 GB GPU VRAM)
#   curl http://localhost:11434/api/tags     # sanity check
#
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL_FAST=hermes3:8b
OLLAMA_MODEL_DEEP=hermes3:70b

# ============================================================================
# OPTIONAL on-chain providers — each fails open with neutral feature values
# ============================================================================

# CryptoQuant — exchange net-flow (BTC, ETH)
# https://cryptoquant.com → user menu → My API Keys
CRYPTOQUANT_API_KEY=

# Whale Alert — large transfers (>= $1M)
# https://docs.whale-alert.io/ → Plans & Billing → Personal (free)
WHALE_ALERT_API_KEY=

# Glassnode — MVRV ratio (note: free tier excludes MVRV; leave blank to skip)
# https://glassnode.com → Account → API
GLASSNODE_API_KEY=

# ============================================================================
# Storage — PostgreSQL + TimescaleDB (port 5434 to avoid ModelForge's 5432)
# ============================================================================
POSTGRES_USER=tradebot
POSTGRES_PASSWORD=tradebot-change-me
POSTGRES_DB=tradebot

# Override only if you're not using docker compose. Inside the compose
# network the dashboard/freqtrade containers reach Postgres via the
# `postgres` service name on the internal port 5432.
# DATABASE_URL=postgresql://tradebot:tradebot-change-me@localhost:5434/tradebot

# ============================================================================
# Monitoring stack
# ============================================================================

# InfluxDB — DEPRECATION PLANNED. Will be replaced by TimescaleDB as the
# sole Grafana datasource. Keep these values populated until migration.
# Used by the metrics writer + Grafana time-series panels.
# (TimescaleDB-backed Grafana datasources are on the roadmap; for now both
# are running so the dashboard JSON keeps working.)
INFLUX_TOKEN=                 # `openssl rand -hex 16`
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=
INFLUX_ORG=trading-bot
INFLUX_BUCKET=trading
INFLUX_RETENTION=90d

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ============================================================================
# Dashboard (TradingView-style chart UI on port 8081)
# ============================================================================
DASHBOARD_PAIRS=BTC/USD,ETH/USD,SOL/USD
DASHBOARD_TIMEFRAME=5m
DASHBOARD_WS_INTERVAL_SEC=30

# ============================================================================
# Freqtrade — env-var overrides (FREQTRADE__SECTION__KEY pattern at runtime)
# ============================================================================
# All secrets live HERE so user_data/config.json can stay in version control
# without leaks. The compose freqtrade service forwards each FREQTRADE_* below
# to the corresponding FREQTRADE__SECTION__KEY env var the bot reads at boot.

# Hermes MCP server (port 8089) — auth key for mutating tools
# (pause_trading, resume_trading, trigger_evolution_cycle). Read-only tools
# stay open so Hermes Agent can fast-path queries.
HERMES_MCP_KEY=                          # `openssl rand -hex 32`

# REST API + WebUI (port 8080).
FREQTRADE_API_USER=freqtrader
FREQTRADE_API_PASS=                      # `openssl rand -hex 24` — strong, no spaces
FREQTRADE_JWT_SECRET=                    # `openssl rand -hex 32` — JWT signing
FREQTRADE_WS_TOKEN=                      # `openssl rand -hex 16` — WS auth token

# Note: FREQTRADE__DB_URL is built automatically from POSTGRES_USER/PASSWORD
# above and pointed at the `freqtrade` database on the postgres service.

# ============================================================================
# Stocks subsystem (Shark + Wheel) — Alpaca-backed, merged here so docker
# compose only needs one .env file. Detailed comments live in
# stocks/env.template; this is the unified placeholder set.
# ============================================================================

# --- Alpaca (paper or live) -------------------------------------------------
# https://app.alpaca.markets → API Keys. Use the paper-trading endpoint until
# the wheel pilot has 4 weeks of clean paper data (see stocks/CLAUDE.md).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex                # iex (free) | sip (paid, all US exchanges)

# --- Shark LLM provider -----------------------------------------------------
# Default: local Ollama (zero cost — same Hermes-3 the crypto sentiment
# engine uses). Set to "anthropic" only if you specifically want Claude
# routing; expect ~$15-20/mo at the pilot's expected cadence.
SHARK_LLM_PROVIDER=ollama
OLLAMA_MODEL=hermes3:70b            # used by deep agents (arbiter / risk / combined)
OLLAMA_FAST_MODEL=hermes3:8b        # used by fast agents (bull / bear / debate / reviewer)
OLLAMA_BASE_URL=http://localhost:11434

# Per-role overrides — handy for A/B'ing models without code change.
# SHARK_DEBATE_LLM_MODEL=hermes3:8b
# SHARK_ARBITER_LLM_MODEL=qwen2.5:72b-instruct

# --- Anthropic (only when SHARK_LLM_PROVIDER=anthropic) ---------------------
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Perplexity (news intel for shark pre-market) ---------------------------
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# --- Wheel pilot tuning -----------------------------------------------------
WHEEL_SYMBOLS=SOFI                  # comma-separated list
WHEEL_MAX_RISK_PER_TICKER=1700      # $ collateral cap per CSP
WHEEL_MAX_TOTAL_COLLATERAL=5000     # $ pilot cap
WHEEL_DELTA_MIN=0.25
WHEEL_DELTA_MAX=0.35
WHEEL_DTE_MIN=7
WHEEL_DTE_MAX=10

# --- Telegram (Hermes cron summaries; Slack handles trade events) ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Unified risk threshold -------------------------------------------------
# Combined crypto + stocks drawdown that trips both kill switches. 0.10 = 10%.
UNIFIED_DRAWDOWN_PCT=0.10

# --- Dashboard polish flags -------------------------------------------------
# Set DASHBOARD_EFFECTS=0 to drop the decorative effects.js layer for a
# data-first display. All functional UI is unchanged.
DASHBOARD_EFFECTS=1
DASHBOARD_STOCK_SYMBOLS=SOFI        # which stock symbols appear in the chart dropdown
