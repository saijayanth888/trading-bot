# Copy to .env in the same directory as docker-compose.yml.
# `docker compose` auto-loads .env at startup.

# CryptoQuant — https://cryptoquant.com/  (free signup → My API Keys)
CRYPTOQUANT_API_KEY=

# Whale Alert — https://docs.whale-alert.io/ (free signup → API key, $500K min, 10 req/min)
WHALE_ALERT_API_KEY=

# Glassnode — https://docs.glassnode.com/ (free tier signup → Account → API)
GLASSNODE_API_KEY=

# ----------------------------------------------------------------------------
# Sentiment engine
# ----------------------------------------------------------------------------

# Anthropic — required for Claude sentiment pass.
# https://console.anthropic.com/  →  Settings → API Keys
ANTHROPIC_API_KEY=

# Override the model if you want to swap to e.g. claude-sonnet-4-6.
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama — defaults assume the host runs `ollama serve` with OLLAMA_HOST=0.0.0.0.
# Inside the container we reach it via host.docker.internal.
# OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.1:8b
