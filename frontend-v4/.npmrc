# Supply-chain cooldown: refuse package versions published in the last 2880 min (= 2 days).
# Defends against fast-yanked compromises (Shai-Hulud / Mini Shai-Hulud / Qix).
# Requires npm >= 11.6.1 — older npm reads but silently ignores this key.
# Override one-off with `npm i --minimum-release-age=0` (think twice first).
minimumReleaseAge=2880
