+def _resolve_cron_worker_count() -> int:
+    """Pick worker-thread count for the cron dispatch pool.
+
+    Precedence: HERMES_CRON_MAX_PARALLEL env var > sensible default (4).
+    Set to 1 to restore fully serial behaviour.  Clamped to [1, 32].
+    """
+    try:
+        env = os.getenv("HERMES_CRON_MAX_PARALLEL", "").strip()
+        if env:
+            n = int(env)
+            if n >= 1:
+                return min(n, 32)
+    except (ValueError, TypeError):
+        logger.warning("Invalid HERMES_CRON_MAX_PARALLEL value; defaulting to 4")
+    return 4
+
+
+def _cron_worker_loop(work_queue: "queue.Queue", stop_event: threading.Event, adapters=None, loop=None):
+    """Long-lived gateway-owned worker thread for cron jobs.
+
+    Pulls one job at a time off ``work_queue`` and runs it via
+    ``cron.scheduler.dispatch_job`` (which internally serializes
+    workdir-jobs on a process-global lock).  Exits cleanly when it
+    receives the sentinel ``None`` on the queue OR when ``stop_event``
+    is set and the queue is drained.
+
+    Workers are dedicated (not a futures pool) so they:
+      * outlive any single tick — no spawn/join cost per tick
+      * never block on _python_exit atexit hooks (they shut down
+        explicitly via the sentinel from _start_cron_ticker)
+      * keep tick() short — the file lock is only held for claim,
+        execution is here in the background
+    """
+    from cron.scheduler import dispatch_job
+
+    while True:
+        try:
+            job = work_queue.get(timeout=1.0)
+        except queue.Empty:
+            if stop_event.is_set():
+                return
+            continue
+        if job is None:
+            # Sentinel — gateway shutdown.
+            try:
+                work_queue.task_done()
+            except Exception:
+                pass
+            return
+        try:
+            dispatch_job(job, adapters=adapters, loop=loop, verbose=False)
+        except Exception as e:
+            logger.error("Cron worker: unhandled error on job %s: %s", job.get("id", "?"), e)
+        finally:
+            try:
+                work_queue.task_done()
+            except Exception:
+                pass
+
