# Shark Trading Agent — Environment Variables
# Copy this to .env for local use. NEVER commit .env to git.
# In cloud routines, set these as environment variables on the routine itself.

# ── Alpaca (paper trading to start) ──────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Switch to https://api.alpaca.markets for live trading
ALPACA_DATA_FEED=iex
# Options: iex (free tier) | sip (paid — all US exchanges)

# ── Perplexity (market research) ─────────────────────────────────────────
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=sonar-pro

# ── Anthropic (agent brain) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Gmail REST API (preferred — works in cloud sandboxes) ────────────────
# One-time setup: run `python scripts/gmail_oauth_setup.py` to get the refresh token.
# See docs/SETUP-GUIDE.md for step-by-step instructions.
GMAIL_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=your_client_secret
GMAIL_OAUTH_REFRESH_TOKEN=your_refresh_token
NOTIFY_EMAIL=your_email@gmail.com
NOTIFY_FROM_EMAIL=your_gmail_address@gmail.com

# ── Gmail SMTP fallback (blocked in most cloud sandboxes) ────────────────
# Only used if OAuth2 vars above are not set.
# Create an App Password at myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# ── Trading Mode ──────────────────────────────────────────────────────────
TRADING_MODE=paper
# Options: paper | live

# ── Paper-Mode Overrides (only apply when TRADING_MODE=paper) ─────────────
# In paper mode, the agent allows limited trading in BEAR regimes so the
# full pipeline can be tested. Set PAPER_BEAR_OVERRIDE=false to disable.
PAPER_BEAR_OVERRIDE=true
PAPER_MACRO_BYPASS=true
PAPER_BEAR_MAX_TRADES=1
PAPER_BEAR_SIZE_MULT=0.5
PAPER_BEAR_CONFIDENCE=0.85
PAPER_BEAR_MIN_SCORE=3

# ── Risk Parameters (overrides CLAUDE.md defaults) ───────────────────────
MAX_POSITIONS=6
MAX_POSITION_PCT=0.20
MAX_WEEKLY_TRADES=3
MIN_CASH_BUFFER_PCT=0.15
CIRCUIT_BREAKER_PCT=0.15
MAX_SECTOR_FAILURES=2
