# Shark Trading Agent — Environment Variables
# Copy this to .env for local use. NEVER commit .env to git.
# In cloud routines, set these as environment variables on the routine itself.

# ── Alpaca (paper trading to start) ──────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Switch to https://api.alpaca.markets for live trading
ALPACA_DATA_FEED=iex
# Options: iex (free tier) | sip (paid — all US exchanges)

# ── Perplexity (market research) ─────────────────────────────────────────
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=sonar-pro

# ── LLM Provider ──────────────────────────────────────────────────────────
# Default: ollama (local, zero cost — same Hermes-3 70B the crypto sentiment
# engine uses). Set to "anthropic" if you prefer Claude (~$15-20/mo at the
# pilot's expected cadence; rule-based fallback kicks in if the key is empty).
SHARK_LLM_PROVIDER=ollama
OLLAMA_MODEL=hermes3:70b
OLLAMA_FAST_MODEL=hermes3:8b
OLLAMA_BASE_URL=http://localhost:11434

# Optional per-role overrides — handy for A/B'ing models without code change.
# Examples:
#   SHARK_DEBATE_LLM_PROVIDER=ollama
#   SHARK_DEBATE_LLM_MODEL=hermes3:8b           # cheaper for debate rounds
#   SHARK_ARBITER_LLM_MODEL=qwen2.5:72b-instruct  # higher quality for the arbiter

# ── Anthropic (only needed when SHARK_LLM_PROVIDER=anthropic) ────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── Gmail REST API (preferred — works in cloud sandboxes) ────────────────
# One-time setup: run `python scripts/gmail_oauth_setup.py` to get the refresh token.
# See docs/SETUP-GUIDE.md for step-by-step instructions.
GMAIL_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=your_client_secret
GMAIL_OAUTH_REFRESH_TOKEN=your_refresh_token
NOTIFY_EMAIL=your_email@gmail.com
NOTIFY_FROM_EMAIL=your_gmail_address@gmail.com

# ── Gmail SMTP fallback (blocked in most cloud sandboxes) ────────────────
# Only used if OAuth2 vars above are not set.
# Create an App Password at myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# ── Trading Mode ──────────────────────────────────────────────────────────
TRADING_MODE=paper
# Options: paper | live

# ── Paper-Mode Overrides (only apply when TRADING_MODE=paper) ─────────────
# Paper mode unconditionally allows BEAR-regime trades and bypasses
# CRITICAL/HIGH macro blocks — that's the whole point of paper mode
# (exercise the full pipeline). The env vars PAPER_BEAR_OVERRIDE and
# PAPER_MACRO_BYPASS used to live here; removed in the 2026-05-14
# stagnant-config audit because they ARE paper mode behavior. The values
# below still tune HOW MUCH paper mode trades, not WHETHER.
PAPER_BEAR_MAX_TRADES=1
PAPER_BEAR_SIZE_MULT=0.5
PAPER_BEAR_CONFIDENCE=0.85
PAPER_BEAR_MIN_SCORE=3

# ── Risk Parameters (overrides CLAUDE.md defaults) ───────────────────────
MAX_POSITIONS=6
MAX_POSITION_PCT=0.20
MAX_WEEKLY_TRADES=3
MIN_CASH_BUFFER_PCT=0.15
CIRCUIT_BREAKER_PCT=0.15
MAX_SECTOR_FAILURES=2
